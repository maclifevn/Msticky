{
  "name": "msticky",
  "version": "0.1.0",
  "private": true,
  "description": "Msticky — realtime sticky notes for Windows & macOS",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "pnpm --filter @msticky/desktop dev",
    "build:shared": "pnpm --filter @msticky/shared build",
    "worker:dev": "pnpm --filter @msticky/sync-worker dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
