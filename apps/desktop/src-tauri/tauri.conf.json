{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Msticky",
  "version": "0.1.18",
  "identifier": "com.msticky.app",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "board",
        "title": "Msticky",
        "width": 840,
        "height": 620,
        "minWidth": 420,
        "minHeight": 360,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Realtime sticky notes",
    "longDescription": "Paper-style sticky notes with realtime sync across Windows and macOS.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
